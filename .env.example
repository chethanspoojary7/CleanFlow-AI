# Backend API base URL for the frontend.
# Use the MACHINE NAME or LAN IP of the computer running the Flask backend.
# Example: VITE_API_BASE=http://192.168.1.50:5000/api
# 
# If you run everything on the same machine, you can keep the default:
# VITE_API_BASE=http://localhost:5000/api
VITE_API_BASE=http://localhost:5000/api

